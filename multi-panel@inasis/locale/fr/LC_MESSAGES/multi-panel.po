msgid "Application Menu"
msgstr "Menu des applications"

msgid "Activities"
msgstr "Activités"

msgid "Accessbility"
msgstr "Accessibilité"

msgid "Keyboard"
msgstr "Clavier"

msgid "Screen Sharing"
msgstr "Partage d'écran"

msgid "Screen Recording"
msgstr "Enregistrement d'écran"

msgid "Quick Settings"
msgstr "Paramètres rapides"

msgid "Date and Clock"
msgstr "Date et horloge"

msgid "Settings"
msgstr "Paramètres"

msgid "Show bar on additional monitors"
msgstr "Afficher la barre sur les moniteurs supplémentaires"

msgid "General"
msgstr "Général"

msgid "General behavior for additional monitors and desktop integration."
msgstr "Comportement général des moniteurs supplémentaires et de l'intégration au bureau."

msgid "Enable hot corners"
msgstr "Activer les coins actifs"

msgid "Show screenshot tools on all monitors"
msgstr "Afficher les outils de capture d'écran sur tous les moniteurs"

msgid "Indicators"
msgstr "Indicateurs"

msgid "Reorder indicators, choose their group, and show or hide them on additional monitors."
msgstr "Réorganisez les indicateurs, choisissez leur groupe et affichez-les ou masquez-les sur les moniteurs supplémentaires."

msgid "Transferred Indicators"
msgstr "Indicateurs transférés"

msgid "Move stable indicators away from the primary bar to a specific monitor."
msgstr "Déplace les indicateurs stables de la barre principale vers un moniteur spécifique."

msgid "Indicators transferred to additional monitors"
msgstr "Indicateurs transférés vers les moniteurs supplémentaires"

msgid "Add indicator"
msgstr "Ajouter un indicateur"

msgid "Remove indicator"
msgstr "Supprimer l'indicateur"

msgid "Left"
msgstr "Gauche"

msgid "Center"
msgstr "Centre"

msgid "Right"
msgstr "Droite"

msgid "Choose where this indicator should appear"
msgstr "Choisir où cet indicateur doit apparaître"

msgid "Show or hide this indicator on Multi Monitor Bar"
msgstr "Afficher ou masquer cet indicateur sur Multi Monitor Bar"

msgid "Select indicator"
msgstr "Sélectionner un indicateur"

msgid "Cancel"
msgstr "Annuler"

msgid "Add"
msgstr "Ajouter"

msgid "Indicators on Top Panel"
msgstr "Indicateurs sur la barre supérieure"

msgid "Monitor index:"
msgstr "Indice du moniteur :"

msgid "Layout"
msgstr "Disposition"

msgid "Adjust internal left and right padding for each indicator on additional monitor bars."
msgstr "Ajuster le remplissage interne gauche et droit de chaque indicateur sur les barres des moniteurs supplémentaires."

msgid "Indicator Padding"
msgstr "Remplissage des indicateurs"

msgid "Adjust internal left and right padding for each indicator."
msgstr "Ajuster le remplissage interne gauche et droit de chaque indicateur."

msgid "Quick Settings gap"
msgstr "Espacement des paramètres rapides"

msgid "Indicator gap"
msgstr "Espacement des indicateurs"

msgid "Panel Layout"
msgstr "Disposition du panneau"

msgid "Adjust panel left and right padding and height."
msgstr "Ajuster le remplissage gauche et droit ainsi que la hauteur du panneau."

msgid "Panel left padding"
msgstr "Remplissage gauche du panneau"

msgid "Panel right padding"
msgstr "Remplissage droit du panneau"

msgid "Panel height"
msgstr "Hauteur du panneau"

msgid "Apply to main panel"
msgstr "Appliquer au panneau principal"

msgid "Use the same panel height, panel padding, and indicator spacing on the primary GNOME top bar."
msgstr "Utiliser la même hauteur de panneau, le même remplissage de panneau et le même espacement des indicateurs sur la barre supérieure GNOME principale."

msgid "Top Bar"
msgstr "Barre supérieure"

msgid "No Notifications"
msgstr "Aucune notification"

msgid "%OB"
msgstr "%OB"

msgid "%OB %Y"
msgstr "%OB %Y"

msgid "Do Not Disturb"
msgstr "Ne pas déranger"

msgid "Clear"
msgstr "Effacer"
