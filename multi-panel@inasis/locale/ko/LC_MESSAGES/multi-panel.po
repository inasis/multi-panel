msgid "Application Menu"
msgstr "응용 프로그램 메뉴"

msgid "Activities"
msgstr "활동"

msgid "Accessbility"
msgstr "접근성"

msgid "Keyboard"
msgstr "키보드"

msgid "Screen Sharing"
msgstr "화면 공유"

msgid "Screen Recording"
msgstr "화면 녹화"

msgid "Quick Settings"
msgstr "빠른 설정"

msgid "Date and Clock"
msgstr "날짜 및 시계"

msgid "Settings"
msgstr "설정"

msgid "Show bar on additional monitors"
msgstr "추가 모니터에 바 표시"

msgid "General"
msgstr "일반"

msgid "General behavior for additional monitors and desktop integration."
msgstr "추가 모니터 및 데스크톱 통합에 대한 일반 동작입니다."

msgid "Enable hot corners"
msgstr "핫 코너 활성화"

msgid "Show screenshot tools on all monitors"
msgstr "모든 모니터에 스크린샷 도구 표시"

msgid "Indicators"
msgstr "인디케이터"

msgid "Reorder indicators, choose their group, and show or hide them on additional monitors."
msgstr "추가 모니터에서 인디케이터 순서를 바꾸고, 그룹을 선택하고, 표시 여부를 설정합니다."

msgid "Transferred Indicators"
msgstr "이동된 인디케이터"

msgid "Move stable indicators away from the primary bar to a specific monitor."
msgstr "기본 바의 고정 인디케이터를 특정 모니터로 이동합니다."

msgid "Indicators transferred to additional monitors"
msgstr "추가 모니터로 이동된 인디케이터"

msgid "Add indicator"
msgstr "인디케이터 추가"

msgid "Remove indicator"
msgstr "인디케이터 제거"

msgid "Left"
msgstr "왼쪽"

msgid "Center"
msgstr "가운데"

msgid "Right"
msgstr "오른쪽"

msgid "Choose where this indicator should appear"
msgstr "이 인디케이터를 표시할 위치를 선택합니다"

msgid "Show or hide this indicator on Multi Monitor Bar"
msgstr "Multi Monitor Bar에서 이 인디케이터를 표시하거나 숨깁니다"

msgid "Select indicator"
msgstr "인디케이터 선택"

msgid "Cancel"
msgstr "취소"

msgid "Add"
msgstr "추가"

msgid "Indicators on Top Panel"
msgstr "상단 패널의 인디케이터"

msgid "Monitor index:"
msgstr "모니터 인덱스:"

msgid "Layout"
msgstr "레이아웃"

msgid "Adjust internal left and right padding for each indicator on additional monitor bars."
msgstr "추가 모니터 바의 각 인디케이터 내부 좌우 패딩을 조정합니다."

msgid "Indicator Padding"
msgstr "인디케이터 패딩"

msgid "Adjust internal left and right padding for each indicator."
msgstr "각 인디케이터의 내부 좌우 패딩을 조정합니다."

msgid "Quick Settings gap"
msgstr "빠른 설정 간격"

msgid "Indicator gap"
msgstr "인디케이터 간격"

msgid "Panel Layout"
msgstr "패널 레이아웃"

msgid "Adjust panel left and right padding and height."
msgstr "패널의 좌우 패딩과 높이를 조정합니다."

msgid "Panel left padding"
msgstr "패널 왼쪽 패딩"

msgid "Panel right padding"
msgstr "패널 오른쪽 패딩"

msgid "Panel height"
msgstr "패널 높이"

msgid "Apply to main panel"
msgstr "메인 패널에도 적용"

msgid "Use the same panel height, panel padding, and indicator spacing on the primary GNOME top bar."
msgstr "기본 GNOME 상단 바에도 같은 패널 높이, 패널 패딩, 인디케이터 간격을 적용합니다."

msgid "Top Bar"
msgstr "상단 바"

msgid "No Notifications"
msgstr "알림 없음"

msgid "%OB"
msgstr "%OB"

msgid "%OB %Y"
msgstr "%OB %Y"

msgid "Do Not Disturb"
msgstr "방해 금지"

msgid "Clear"
msgstr "지우기"
