msgid "Application Menu"
msgstr "Programmenu"

msgid "Activities"
msgstr "Aktiviteter"

msgid "Accessbility"
msgstr "Tilgængelighed"

msgid "Keyboard"
msgstr "Tastatur"

msgid "Screen Sharing"
msgstr "Skærmdeling"

msgid "Screen Recording"
msgstr "Skærmoptagelse"

msgid "Quick Settings"
msgstr "Hurtigindstillinger"

msgid "Date and Clock"
msgstr "Dato og ur"

msgid "Settings"
msgstr "Indstillinger"

msgid "Show bar on additional monitors"
msgstr "Vis bjælken på ekstra skærme"

msgid "General"
msgstr "Generelt"

msgid "General behavior for additional monitors and desktop integration."
msgstr "Generel opførsel for ekstra skærme og desktopintegration."

msgid "Enable hot corners"
msgstr "Aktivér varme hjørner"

msgid "Show screenshot tools on all monitors"
msgstr "Vis skærmbilledeværktøjer på alle skærme"

msgid "Indicators"
msgstr "Indikatorer"

msgid "Reorder indicators, choose their group, and show or hide them on additional monitors."
msgstr "Omarrangér indikatorer, vælg deres gruppe, og vis eller skjul dem på ekstra skærme."

msgid "Transferred Indicators"
msgstr "Overførte indikatorer"

msgid "Move stable indicators away from the primary bar to a specific monitor."
msgstr "Flyt stabile indikatorer væk fra hovedbjælken til en bestemt skærm."

msgid "Indicators transferred to additional monitors"
msgstr "Indikatorer overført til ekstra skærme"

msgid "Add indicator"
msgstr "Tilføj indikator"

msgid "Remove indicator"
msgstr "Fjern indikator"

msgid "Left"
msgstr "Venstre"

msgid "Center"
msgstr "Midten"

msgid "Right"
msgstr "Højre"

msgid "Choose where this indicator should appear"
msgstr "Vælg hvor denne indikator skal vises"

msgid "Show or hide this indicator on Multi Monitor Bar"
msgstr "Vis eller skjul denne indikator på Multi Monitor Bar"

msgid "Select indicator"
msgstr "Vælg indikator"

msgid "Cancel"
msgstr "Annullér"

msgid "Add"
msgstr "Tilføj"

msgid "Indicators on Top Panel"
msgstr "Indikatorer på toppanelet"

msgid "Monitor index:"
msgstr "Skærmindeks:"

msgid "Layout"
msgstr "Layout"

msgid "Adjust internal left and right padding for each indicator on additional monitor bars."
msgstr "Juster intern venstre og højre polstring for hver indikator på ekstra skærmbjælker."

msgid "Indicator Padding"
msgstr "Indikatorpolstring"

msgid "Adjust internal left and right padding for each indicator."
msgstr "Juster intern venstre og højre polstring for hver indikator."

msgid "Quick Settings gap"
msgstr "Afstand i hurtigindstillinger"

msgid "Indicator gap"
msgstr "Indikatorafstand"

msgid "Panel Layout"
msgstr "Panellayout"

msgid "Adjust panel left and right padding and height."
msgstr "Juster panelets venstre og højre polstring samt højde."

msgid "Panel left padding"
msgstr "Venstre panelpolstring"

msgid "Panel right padding"
msgstr "Højre panelpolstring"

msgid "Panel height"
msgstr "Panelhøjde"

msgid "Apply to main panel"
msgstr "Anvend på hovedpanel"

msgid "Use the same panel height, panel padding, and indicator spacing on the primary GNOME top bar."
msgstr "Brug samme panelhøjde, panelpolstring og indikatorafstand på GNOME's primære topbjælke."

msgid "Top Bar"
msgstr "Topbjælke"

msgid "No Notifications"
msgstr "Ingen notifikationer"

msgid "%OB"
msgstr "%OB"

msgid "%OB %Y"
msgstr "%OB %Y"

msgid "Do Not Disturb"
msgstr "Forstyr ikke"

msgid "Clear"
msgstr "Ryd"
