msgid "Application Menu"
msgstr "Menu aplikacji"

msgid "Activities"
msgstr "Aktywności"

msgid "Accessbility"
msgstr "Dostępność"

msgid "Keyboard"
msgstr "Klawiatura"

msgid "Screen Sharing"
msgstr "Udostępnianie ekranu"

msgid "Screen Recording"
msgstr "Nagrywanie ekranu"

msgid "Quick Settings"
msgstr "Szybkie ustawienia"

msgid "Date and Clock"
msgstr "Data i zegar"

msgid "Settings"
msgstr "Ustawienia"

msgid "Show bar on additional monitors"
msgstr "Pokaż pasek na dodatkowych monitorach"

msgid "General"
msgstr "Ogólne"

msgid "General behavior for additional monitors and desktop integration."
msgstr "Ogólne zachowanie dodatkowych monitorów i integracji z pulpitem."

msgid "Enable hot corners"
msgstr "Włącz aktywne rogi"

msgid "Show screenshot tools on all monitors"
msgstr "Pokaż narzędzia zrzutu ekranu na wszystkich monitorach"

msgid "Indicators"
msgstr "Wskaźniki"

msgid "Reorder indicators, choose their group, and show or hide them on additional monitors."
msgstr "Zmień kolejność wskaźników, wybierz ich grupę oraz pokaż lub ukryj je na dodatkowych monitorach."

msgid "Transferred Indicators"
msgstr "Przeniesione wskaźniki"

msgid "Move stable indicators away from the primary bar to a specific monitor."
msgstr "Przenieś stałe wskaźniki z głównego paska na wybrany monitor."

msgid "Indicators transferred to additional monitors"
msgstr "Wskaźniki przeniesione na dodatkowe monitory"

msgid "Add indicator"
msgstr "Dodaj wskaźnik"

msgid "Remove indicator"
msgstr "Usuń wskaźnik"

msgid "Left"
msgstr "Lewo"

msgid "Center"
msgstr "Środek"

msgid "Right"
msgstr "Prawo"

msgid "Choose where this indicator should appear"
msgstr "Wybierz, gdzie ten wskaźnik ma się pojawić"

msgid "Show or hide this indicator on Multi Monitor Bar"
msgstr "Pokaż lub ukryj ten wskaźnik na pasku Multi Monitor Bar"

msgid "Select indicator"
msgstr "Wybierz wskaźnik"

msgid "Cancel"
msgstr "Anuluj"

msgid "Add"
msgstr "Dodaj"

msgid "Indicators on Top Panel"
msgstr "Wskaźniki na górnym pasku"

msgid "Monitor index:"
msgstr "Indeks monitora:"

msgid "Layout"
msgstr "Układ"

msgid "Adjust internal left and right padding for each indicator on additional monitor bars."
msgstr "Dostosuj wewnętrzne lewe i prawe wypełnienie dla każdego wskaźnika na paskach dodatkowych monitorów."

msgid "Indicator Padding"
msgstr "Wypełnienie wskaźnika"

msgid "Adjust internal left and right padding for each indicator."
msgstr "Dostosuj wewnętrzne lewe i prawe wypełnienie dla każdego wskaźnika."

msgid "Quick Settings gap"
msgstr "Odstęp szybkich ustawień"

msgid "Indicator gap"
msgstr "Odstęp wskaźników"

msgid "Panel Layout"
msgstr "Układ panelu"

msgid "Adjust panel left and right padding and height."
msgstr "Dostosuj lewe i prawe wypełnienie oraz wysokość panelu."

msgid "Panel left padding"
msgstr "Lewe wypełnienie panelu"

msgid "Panel right padding"
msgstr "Prawe wypełnienie panelu"

msgid "Panel height"
msgstr "Wysokość panelu"

msgid "Apply to main panel"
msgstr "Zastosuj do panelu głównego"

msgid "Use the same panel height, panel padding, and indicator spacing on the primary GNOME top bar."
msgstr "Użyj tej samej wysokości panelu, tego samego wypełnienia panelu i tych samych odstępów między wskaźnikami na głównym górnym pasku GNOME."

msgid "Top Bar"
msgstr "Górny pasek"

msgid "No Notifications"
msgstr "Brak powiadomień"

msgid "%OB"
msgstr "%OB"

msgid "%OB %Y"
msgstr "%OB %Y"

msgid "Do Not Disturb"
msgstr "Nie przeszkadzać"

msgid "Clear"
msgstr "Wyczyść"
