msgid "Application Menu"
msgstr "Menu applicazioni"

msgid "Activities"
msgstr "Attività"

msgid "Accessbility"
msgstr "Accessibilità"

msgid "Keyboard"
msgstr "Tastiera"

msgid "Screen Sharing"
msgstr "Condivisione schermo"

msgid "Screen Recording"
msgstr "Registrazione schermo"

msgid "Quick Settings"
msgstr "Impostazioni rapide"

msgid "Date and Clock"
msgstr "Data e orologio"

msgid "Settings"
msgstr "Impostazioni"

msgid "Show bar on additional monitors"
msgstr "Mostra la barra sui monitor aggiuntivi"

msgid "General"
msgstr "Generale"

msgid "General behavior for additional monitors and desktop integration."
msgstr "Comportamento generale per i monitor aggiuntivi e l'integrazione con il desktop."

msgid "Enable hot corners"
msgstr "Abilita angoli attivi"

msgid "Show screenshot tools on all monitors"
msgstr "Mostra gli strumenti di screenshot su tutti i monitor"

msgid "Indicators"
msgstr "Indicatori"

msgid "Reorder indicators, choose their group, and show or hide them on additional monitors."
msgstr "Riordina gli indicatori, scegli il loro gruppo e mostrali o nascondili sui monitor aggiuntivi."

msgid "Transferred Indicators"
msgstr "Indicatori trasferiti"

msgid "Move stable indicators away from the primary bar to a specific monitor."
msgstr "Sposta gli indicatori stabili dalla barra principale a un monitor specifico."

msgid "Indicators transferred to additional monitors"
msgstr "Indicatori trasferiti ai monitor aggiuntivi"

msgid "Add indicator"
msgstr "Aggiungi indicatore"

msgid "Remove indicator"
msgstr "Rimuovi indicatore"

msgid "Left"
msgstr "Sinistra"

msgid "Center"
msgstr "Centro"

msgid "Right"
msgstr "Destra"

msgid "Choose where this indicator should appear"
msgstr "Scegli dove deve apparire questo indicatore"

msgid "Show or hide this indicator on Multi Monitor Bar"
msgstr "Mostra o nascondi questo indicatore sulla Multi Monitor Bar"

msgid "Select indicator"
msgstr "Seleziona indicatore"

msgid "Cancel"
msgstr "Annulla"

msgid "Add"
msgstr "Aggiungi"

msgid "Indicators on Top Panel"
msgstr "Indicatori sulla barra superiore"

msgid "Monitor index:"
msgstr "Indice monitor:"

msgid "Layout"
msgstr "Layout"

msgid "Adjust internal left and right padding for each indicator on additional monitor bars."
msgstr "Regola il padding interno sinistro e destro per ogni indicatore sulle barre dei monitor aggiuntivi."

msgid "Indicator Padding"
msgstr "Padding indicatore"

msgid "Adjust internal left and right padding for each indicator."
msgstr "Regola il padding interno sinistro e destro per ogni indicatore."

msgid "Quick Settings gap"
msgstr "Spaziatura impostazioni rapide"

msgid "Indicator gap"
msgstr "Spaziatura indicatori"

msgid "Panel Layout"
msgstr "Layout pannello"

msgid "Adjust panel left and right padding and height."
msgstr "Regola il padding sinistro e destro e l'altezza del pannello."

msgid "Panel left padding"
msgstr "Padding sinistro pannello"

msgid "Panel right padding"
msgstr "Padding destro pannello"

msgid "Panel height"
msgstr "Altezza pannello"

msgid "Apply to main panel"
msgstr "Applica al pannello principale"

msgid "Use the same panel height, panel padding, and indicator spacing on the primary GNOME top bar."
msgstr "Usa la stessa altezza del pannello, lo stesso padding del pannello e la stessa spaziatura degli indicatori sulla barra superiore GNOME principale."

msgid "Top Bar"
msgstr "Barra superiore"

msgid "No Notifications"
msgstr "Nessuna notifica"

msgid "%OB"
msgstr "%OB"

msgid "%OB %Y"
msgstr "%OB %Y"

msgid "Do Not Disturb"
msgstr "Non disturbare"

msgid "Clear"
msgstr "Cancella"
